{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "tags": {
      "additionalProperties": false,
      "description": "A mapping of tag names to an array of filenames.",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "tags"
  ],
  "title": "Tags Tracking Schema",
  "type": "object"
}
